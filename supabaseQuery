
CREATE TABLE tailor.users (
id BIGSERIAL PRIMARY KEY,
name VARCHAR(255) NOT NULL,
email VARCHAR(255) UNIQUE NOT NULL,
phone VARCHAR(20) UNIQUE NOT NULL,
password VARCHAR(255) NOT NULL,
role TEXT CHECK (role IN ('customer','tailor','admin')) DEFAULT 'customer',
status BOOLEAN DEFAULT TRUE,
email_verified_at TIMESTAMP,
remember_token VARCHAR(100),
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.user_profiles (
id BIGSERIAL PRIMARY KEY,
user_id BIGINT,
gender TEXT CHECK (gender IN ('male','female','other')),
date_of_birth DATE,
profile_image VARCHAR(255),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (user_id)
REFERENCES users(id)
ON DELETE CASCADE
);

CREATE TABLE tailor.user_addresses (
    id BIGSERIAL PRIMARY KEY,
    user_id BIGINT NOT NULL,
    name VARCHAR(255) NOT NULL,
    phone VARCHAR(20) NOT NULL,
    address_line1 VARCHAR(255) NOT NULL,
    address_line2 VARCHAR(255),
    city VARCHAR(255) NOT NULL,
    state VARCHAR(255) NOT NULL,
    pincode VARCHAR(10) NOT NULL,
    is_default BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,

    CONSTRAINT fk_user_addresses_user
    FOREIGN KEY (user_id)
    REFERENCES users(id)
    ON DELETE CASCADE
);

CREATE TABLE tailor.tailors (
id BIGSERIAL PRIMARY KEY,
user_id BIGINT,
shop_name VARCHAR(255),
experience_years INTEGER DEFAULT 0,
description TEXT,
rating DECIMAL(3,2) DEFAULT 0,
is_verified BOOLEAN DEFAULT FALSE,
status BOOLEAN DEFAULT TRUE,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (user_id)
REFERENCES users(id)
ON DELETE CASCADE
);
CREATE TABLE tailor.tailor_locations (
    id BIGSERIAL PRIMARY KEY,
    tailor_id BIGINT NOT NULL,
    address VARCHAR(255) NOT NULL,
    city VARCHAR(255) NOT NULL,
    state VARCHAR(255) NOT NULL,
    pincode VARCHAR(10) NOT NULL,
    latitude DECIMAL(10,7),
    longitude DECIMAL(10,7),
    created_at TIMESTAMP,
    updated_at TIMESTAMP,

    CONSTRAINT fk_tailor_locations_tailor
    FOREIGN KEY (tailor_id)
    REFERENCES users(id)
    ON DELETE CASCADE
);

CREATE TABLE tailor.tailor_portfolios (
    id BIGSERIAL PRIMARY KEY,
    tailor_id BIGINT NOT NULL,
    image VARCHAR(255) NOT NULL,
    description TEXT,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,

    CONSTRAINT fk_tailor_portfolios_tailor
    FOREIGN KEY (tailor_id)
    REFERENCES users(id)
    ON DELETE CASCADE
);

CREATE TABLE tailor.tailor_services (
    id BIGSERIAL PRIMARY KEY,
    tailor_id BIGINT NOT NULL,
    service_name VARCHAR(255) NOT NULL,
    price DECIMAL(10,2) NOT NULL,
    delivery_days INTEGER NOT NULL,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,

    CONSTRAINT fk_tailor_services_tailor
    FOREIGN KEY (tailor_id)
    REFERENCES users(id)
    ON DELETE CASCADE
);

CREATE TABLE tailor.tailor_availability (
    id BIGSERIAL PRIMARY KEY,
    tailor_id BIGINT NOT NULL,
    day_of_week VARCHAR(10) CHECK (day_of_week IN (
        'monday','tuesday','wednesday','thursday','friday','saturday','sunday'
    )),
    start_time TIME NOT NULL,
    end_time TIME NOT NULL,
    is_available BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,

    CONSTRAINT fk_tailor_availability_tailor
    FOREIGN KEY (tailor_id)
    REFERENCES users(id)
    ON DELETE CASCADE
);

CREATE TABLE tailor.tailor_holidays (
    id BIGSERIAL PRIMARY KEY,
    tailor_id BIGINT NOT NULL,
    date DATE NOT NULL,
    reason VARCHAR(255),
    created_at TIMESTAMP,
    updated_at TIMESTAMP,

    CONSTRAINT fk_tailor_holidays_tailor
    FOREIGN KEY (tailor_id)
    REFERENCES users(id)
    ON DELETE CASCADE
);

CREATE TABLE tailor.categories (
id BIGSERIAL PRIMARY KEY,
name VARCHAR(255) NOT NULL,
image VARCHAR(255),
status BOOLEAN DEFAULT TRUE,
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.subcategories (
id BIGSERIAL PRIMARY KEY,
category_id BIGINT,
name VARCHAR(255),
image VARCHAR(255),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (category_id)
REFERENCES categories(id)
ON DELETE CASCADE
);

CREATE TABLE tailor.designs (
id BIGSERIAL PRIMARY KEY,
tailor_id BIGINT,
category_id BIGINT,
subcategory_id BIGINT,
name VARCHAR(255),
description TEXT,
price DECIMAL(10,2),
status BOOLEAN DEFAULT TRUE,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (tailor_id) REFERENCES tailors(id) ON DELETE CASCADE,
FOREIGN KEY (category_id) REFERENCES categories(id) ON DELETE CASCADE,
FOREIGN KEY (subcategory_id) REFERENCES subcategories(id) ON DELETE CASCADE
);

CREATE TABLE tailor.design_images (
id BIGSERIAL PRIMARY KEY,
design_id BIGINT,
image VARCHAR(255),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (design_id)
REFERENCES designs(id)
ON DELETE CASCADE
);

CREATE TABLE tailor.orders (
id BIGSERIAL PRIMARY KEY,
order_number VARCHAR(100) UNIQUE,
user_id BIGINT,
tailor_id BIGINT,
total_amount DECIMAL(10,2),
delivery_type VARCHAR(50),
delivery_charge DECIMAL(10,2) DEFAULT 0,
address_id BIGINT,
status VARCHAR(50) DEFAULT 'pending',
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
FOREIGN KEY (tailor_id) REFERENCES tailors(id) ON DELETE CASCADE,
FOREIGN KEY (address_id) REFERENCES user_addresses(id) ON DELETE SET NULL
);

CREATE TABLE tailor.order_items (
id BIGSERIAL PRIMARY KEY,
order_id BIGINT,
design_id BIGINT,
quantity INTEGER,
price DECIMAL(10,2),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
FOREIGN KEY (design_id) REFERENCES designs(id) ON DELETE CASCADE
);

CREATE TABLE tailor.measurements (
id BIGSERIAL PRIMARY KEY,
user_id BIGINT,
name VARCHAR(255),
chest DECIMAL(5,2),
waist DECIMAL(5,2),
hip DECIMAL(5,2),
shoulder DECIMAL(5,2),
sleeve_length DECIMAL(5,2),
dress_length DECIMAL(5,2),
notes TEXT,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (user_id)
REFERENCES users(id)
ON DELETE CASCADE
);

CREATE TABLE tailor.payments (
id BIGSERIAL PRIMARY KEY,
order_id BIGINT,
payment_method VARCHAR(100),
transaction_id VARCHAR(255),
amount DECIMAL(10,2),
status VARCHAR(50) DEFAULT 'pending',
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (order_id)
REFERENCES orders(id)
ON DELETE CASCADE
);

CREATE TABLE tailor.refunds (
id BIGSERIAL PRIMARY KEY,
payment_id BIGINT,
amount DECIMAL(10,2),
reason TEXT,
status VARCHAR(50) DEFAULT 'pending',
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (payment_id)
REFERENCES payments(id)
ON DELETE CASCADE
);


CREATE TABLE tailor.reviews (
id BIGSERIAL PRIMARY KEY,
order_id BIGINT,
user_id BIGINT,
tailor_id BIGINT,
rating INTEGER,
review TEXT,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
FOREIGN KEY (tailor_id) REFERENCES tailors(id) ON DELETE CASCADE
);

CREATE TABLE tailor.chats (
id BIGSERIAL PRIMARY KEY,
order_id BIGINT,
customer_id BIGINT,
tailor_id BIGINT,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
FOREIGN KEY (customer_id) REFERENCES users(id) ON DELETE CASCADE,
FOREIGN KEY (tailor_id) REFERENCES tailors(id) ON DELETE CASCADE
);

CREATE TABLE tailor.chat_messages (
id BIGSERIAL PRIMARY KEY,
chat_id BIGINT,
sender_id BIGINT,
message TEXT,
image VARCHAR(255),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (chat_id) REFERENCES chats(id) ON DELETE CASCADE,
FOREIGN KEY (sender_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE tailor.wishlists (
id BIGSERIAL PRIMARY KEY,
user_id BIGINT,
design_id BIGINT,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
FOREIGN KEY (design_id) REFERENCES designs(id) ON DELETE CASCADE
);

CREATE TABLE tailor.coupons (
id BIGSERIAL PRIMARY KEY,
code VARCHAR(100) UNIQUE,
discount_type TEXT CHECK (discount_type IN ('percentage','fixed')),
discount_value DECIMAL(10,2),
max_usage INTEGER,
used_count INTEGER DEFAULT 0,
expires_at TIMESTAMP,
status BOOLEAN DEFAULT TRUE,
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.coupon_usages (
id BIGSERIAL PRIMARY KEY,
coupon_id BIGINT,
user_id BIGINT,
order_id BIGINT,
used_at TIMESTAMP,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (coupon_id) REFERENCES coupons(id) ON DELETE CASCADE,
FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE
);

CREATE TABLE tailor.notifications (
id BIGSERIAL PRIMARY KEY,
user_id BIGINT,
title VARCHAR(255),
message TEXT,
is_read BOOLEAN DEFAULT FALSE,
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

CREATE TABLE tailor.admin_logs (
id BIGSERIAL PRIMARY KEY,
admin_id BIGINT,
action VARCHAR(255),
description TEXT,
ip_address VARCHAR(45),
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.reports (
id BIGSERIAL PRIMARY KEY,
user_id BIGINT,
order_id BIGINT,
reason TEXT,
status VARCHAR(50) DEFAULT 'pending',
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.settings (
id BIGSERIAL PRIMARY KEY,
"key" VARCHAR(255) UNIQUE,
value TEXT,
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.cities (
id BIGSERIAL PRIMARY KEY,
name VARCHAR(255),
state VARCHAR(255),
country VARCHAR(255) DEFAULT 'India',
status BOOLEAN DEFAULT TRUE,
created_at TIMESTAMP,
updated_at TIMESTAMP
);

CREATE TABLE tailor.delivery_charges (
id BIGSERIAL PRIMARY KEY,
city_id BIGINT,
charge DECIMAL(10,2),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (city_id) REFERENCES cities(id) ON DELETE CASCADE
);

CREATE TABLE tailor.commissions (
id BIGSERIAL PRIMARY KEY,
order_id BIGINT,
tailor_id BIGINT,
order_amount DECIMAL(10,2),
platform_commission DECIMAL(10,2),
tailor_earning DECIMAL(10,2),
created_at TIMESTAMP,
updated_at TIMESTAMP,

FOREIGN KEY (order_id) REFERENCES orders(id) ON DELETE CASCADE,
FOREIGN KEY (tailor_id) REFERENCES tailors(id) ON DELETE CASCADE
);